<odoo>

    <!-- ************************************************************ -->
    <!-- MRP Bill of Materials - Form -->
    <!-- ************************************************************ -->

    <record id="view_mrp_bom_form" model="ir.ui.view">
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//group/group" position="inside">
              <field name="display_set_quantity_with_net_quantities" invisible="1" />
              <label for="bom_components_total_net_weight" />
              <div>
                <field name="bom_components_total_net_weight" class="oe_inline" />
                <span> kg</span>
                <button
                        name="set_bom_quantity_with_net_quantities"
                        string="⇑ Update BoM quantity"
                        type="object"
                        class="oe_link"
                        help="It will set BoM quantity with sum of net weight quantities"
                        attrs="{'invisible': [('display_set_quantity_with_net_quantities', '=', False)]}"
                    />
              </div>
              <label for="bom_components_total_gross_weight" />
              <div>
                  <field name="bom_components_total_gross_weight" class="oe_inline" />
                  <span> kg</span>
              </div>

            </xpath>
            <!-- BoM Lines -->
            <xpath
                expr="//field[@name='bom_line_ids']/tree/field[@name='product_uom_id']"
                position="after"
            >
              <field
                    name="line_gross_weight"
                    groups="base.group_no_one"
                    optional="show"
                />
              <field name="line_net_weight" sum="Net weight (kg)" optional="show" />
              <field name="line_net_weight_percentage" optional="show" />
            </xpath>
        </field>
    </record>

</odoo>
