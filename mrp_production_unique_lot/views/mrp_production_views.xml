<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="mrp_production_form_view_unique_lot" model="ir.ui.view">
        <field name="name">mrp.production.form.unique.lot</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view" />
        <field name="arch" type="xml">
            <field name="lot_producing_id" position="before">
                <field name="allowed_lot_producing_ids" invisible="1" />
            </field>
            <field name="lot_producing_id" position="attributes">
                <attribute
                    name="domain"
                >[('id', 'in', allowed_lot_producing_ids)]</attribute>
            </field>
        </field>
    </record>
</odoo>
